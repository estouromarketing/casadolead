---
const services = [
  {
    title: 'Gestão de Tráfego Pago (Ads)',
    description: 'Campanhas otimizadas no Google, Instagram e Facebook para gerar leads prontos para o comercial.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="40" height="40"><path d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/></svg>`,
  },
  {
    title: 'Otimização de Google Meu Negócio (GMN)',
    description: 'Seja a primeira opção no mapa! Colocamos sua empresa em destaque nas buscas locais, aumentando chamadas e rotas.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="40" height="40"><path d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>`,
  },
  {
    title: 'Estratégias de Remarketing',
    description: 'Não perca vendas. Reimpactamos quem já visitou seu site ou perfil, mantendo sua marca na mente do consumidor.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="40" height="40"><path d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>`,
  },
  {
    title: 'Consultoria de Conversão',
    description: 'Analisamos seu processo de vendas para garantir que o lead gerado se torne dinheiro no caixa.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="40" height="40"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>`,
  },
];
---
<section id="servicos" class="services-section">
  <div class="container">
    <div class="services-header anim-hidden">
      <span class="label">Nossos Serviços</span>
      <h2 class="section-title" style="margin-top:12px; font-size:clamp(28px,4vw,44px)">
        Soluções Poderosas
      </h2>
      <p class="services-intro">
        Anúncios online que trazem clientes de verdade. Na Casa do Lead, transformamos seu investimento em mais vendas e resultados comprovados.
      </p>
    </div>
    <div class="services-grid">
      {services.map((svc, i) => (
        <div class={`service-card anim-hidden`} style={`--delay:${i * 100}ms`}>
          <div class="service-icon" set:html={svc.icon}></div>
          <h3 class="service-title">{svc.title}</h3>
          <p class="service-desc">{svc.description}</p>
        </div>
      ))}
    </div>

    <div class="services-cta anim-hidden" style="--delay:400ms">
      <a href="https://wa.me/5511943722083?text=Quero+saber+mais+sobre+os+planos+da+Casa+do+Lead!"
         class="btn" target="_blank" rel="noopener">
        O plano ideal para seu sucesso...
      </a>
    </div>
  </div>
</section>

<style>
.services-section {
  background: var(--color-primary);
  padding: 96px 0;
}
.services-header {
  text-align: center;
  margin-bottom: 56px;
}
.services-intro {
  font-size: 15px;
  color: var(--color-text);
  max-width: 560px;
  margin: 16px auto 0;
  line-height: 1.8em;
}
.services-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
}
.service-card {
  background: var(--color-dark2);
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 16px;
  padding: 36px 28px;
  transition: transform 0.3s, border-color 0.3s, background 0.3s, transition-delay var(--delay, 0ms);
  cursor: default;
}
.service-card:hover {
  transform: scale(1.05);
  border-color: var(--color-orange);
  background: rgba(245,144,13,0.06);
}
.service-icon {
  color: var(--color-orange);
  margin-bottom: 20px;
}
.service-title {
  font-family: var(--font-heading);
  font-size: 18px;
  font-weight: 700;
  color: var(--color-white);
  margin-bottom: 12px;
  line-height: 1.3em;
}
.service-desc {
  font-size: 14px;
  line-height: 1.7em;
  color: var(--color-text);
}
.service-card { transition-delay: var(--delay, 0ms); }
.services-cta {
  text-align: center;
  margin-top: 48px;
  transition-delay: var(--delay, 0ms);
}

@media (max-width: 1024px) {
  .services-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 480px) {
  .services-grid { grid-template-columns: 1fr; }
}
</style>
