---
const posts = [
  {
    title: 'Seu negócio está precisando de mais clientes? Vamos mudar esse cenário!',
    date: '9 de março de 2026',
    category: 'ADS',
    image: '/images/blog-1.jpg',
    slug: '#',
  },
  {
    title: 'Como Gerar Mais Leads para o Seu Negócio em 2026',
    date: '9 de março de 2026',
    category: 'ADS',
    image: '/images/blog-2.jpg',
    slug: '#',
  },
];
---
<section id="blog" class="blog-section">
  <div class="container">
    <div class="blog-header anim-hidden">
      <span class="label">Blog</span>
      <h2 class="section-title blog-title">Novidades</h2>
      <p class="blog-sub">Dicas, novidades e conteúdo direto ao ponto para ajudar seu negócio a crescer.</p>
    </div>
    <div class="blog-grid">
      {posts.map((post, i) => (
        <article class="blog-card anim-hidden anim-zoom" style={`--delay:${i * 150}ms`}>
          <a href={post.slug} class="blog-card-img-wrap">
            <img src={post.image} alt={post.title} width="300" height="300" loading="lazy" />
            <span class="blog-category">{post.category}</span>
          </a>
          <div class="blog-card-body">
            <time class="blog-date">{post.date}</time>
            <h3 class="blog-card-title">
              <a href={post.slug}>{post.title}</a>
            </h3>
          </div>
        </article>
      ))}
    </div>

    <div class="blog-cta anim-hidden" style="--delay:300ms">
      <a href="https://wa.me/5511943722083?text=Quero+saber+mais+sobre+a+Casa+do+Lead!"
         class="btn" target="_blank" rel="noopener">
        Fale com a Gente
      </a>
      <a href="#blog" class="btn btn-outline">
        Nosso Blog
      </a>
    </div>
  </div>
</section>

<style>
.blog-section {
  background: var(--color-primary);
  padding: 96px 0;
}
.blog-header {
  text-align: center;
  margin-bottom: 56px;
}
.blog-title {
  font-size: clamp(28px, 4vw, 44px);
  margin: 12px 0 12px;
}
.blog-sub { font-size: 15px; color: var(--color-text); }
.blog-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 32px;
  max-width: 800px;
  margin: 0 auto;
}
.blog-card {
  background: var(--color-dark2);
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 16px;
  overflow: hidden;
  transition: border-color 0.3s, transform 0.3s, transition-delay var(--delay, 0ms);
}
.blog-card:hover { border-color: var(--color-orange); transform: translateY(-4px); }
.blog-card-img-wrap {
  display: block;
  position: relative;
  aspect-ratio: 1;
  overflow: hidden;
}
.blog-card-img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s;
}
.blog-card:hover .blog-card-img-wrap img { transform: scale(1.05); }
.blog-category {
  position: absolute;
  top: 12px;
  left: 12px;
  background: var(--color-orange);
  color: var(--color-white);
  font-family: var(--font-label);
  font-size: 11px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 1px;
  padding: 4px 10px;
  border-radius: 4px;
}
.blog-card-body { padding: 20px; }
.blog-date {
  font-family: var(--font-label);
  font-size: 12px;
  color: var(--color-text);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.blog-card-title {
  font-family: var(--font-heading);
  font-size: 16px;
  font-weight: 700;
  color: var(--color-white);
  line-height: 1.4em;
  margin-top: 8px;
}
.blog-card-title a { transition: color 0.2s; }
.blog-card-title a:hover { color: var(--color-orange); }
.blog-card { transition-delay: var(--delay, 0ms); }

.blog-cta {
  display: flex;
  justify-content: center;
  gap: 16px;
  margin-top: 48px;
  flex-wrap: wrap;
  transition-delay: var(--delay, 0ms);
}

@media (max-width: 600px) {
  .blog-grid { grid-template-columns: 1fr; max-width: 380px; }
}
</style>
