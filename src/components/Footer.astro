<style>
.site-footer {
  background: var(--color-dark);
  border-top: 1px solid rgba(255,255,255,0.06);
}
.footer-inner {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  gap: 64px;
  padding: 80px 24px;
  align-items: start;
}
.footer-divider {
  width: 1px;
  background: rgba(255,255,255,0.08);
  align-self: stretch;
}
.footer-nl-title {
  font-family: var(--font-heading);
  font-size: 22px;
  font-weight: 700;
  color: var(--color-white);
  margin: 12px 0 10px;
}
.footer-nl-desc {
  font-size: 14px;
  color: var(--color-text);
  line-height: 1.6em;
  margin-bottom: 20px;
  max-width: 340px;
}
.nl-form {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}
.nl-input {
  flex: 1;
  min-width: 200px;
  background: var(--color-dark2);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: var(--radius);
  padding: 12px 16px;
  font-family: var(--font-body);
  font-size: 14px;
  color: var(--color-white);
  outline: none;
  transition: border-color 0.2s;
}
.nl-input::placeholder { color: var(--color-text); }
.nl-input:focus { border-color: var(--color-orange); }
.nl-btn { white-space: nowrap; flex-shrink: 0; }
.nl-success {
  display: none;
  margin-top: 10px;
  color: var(--color-orange);
  font-size: 14px;
}
.nl-success.show { display: block; }

.contact-list {
  list-style: none;
  margin-top: 16px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.contact-link {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 14px;
  color: var(--color-text);
  transition: color 0.2s;
}
.contact-link:hover { color: var(--color-orange); }
.contact-service {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 14px;
  color: var(--color-text);
}
.footer-bottom {
  border-top: 1px solid rgba(255,255,255,0.06);
  padding: 20px 0;
}
.footer-bottom-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 12px;
}
.copyright {
  font-size: 13px;
  color: var(--color-text);
}
.copyright a { color: var(--color-orange); transition: opacity 0.2s; }
.copyright a:hover { opacity: 0.8; }
.footer-links {
  display: flex;
  gap: 24px;
}
.footer-links a {
  font-size: 13px;
  color: var(--color-text);
  transition: color 0.2s;
}
.footer-links a:hover { color: var(--color-orange); }

@media (max-width: 880px) {
  .footer-inner { grid-template-columns: 1fr; gap: 40px; }
  .footer-divider { display: none; }
}
@media (max-width: 480px) {
  .footer-bottom-inner { flex-direction: column; align-items: flex-start; }
  .footer-links { flex-direction: column; gap: 12px; }
}
</style>

<script>
  const form = document.getElementById('nl-form') as HTMLFormElement;
  const success = document.getElementById('nl-success');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' },
      });
      if (res.ok) {
        form.reset();
        success?.classList.add('show');
      }
    } catch {}
  });
</script>
