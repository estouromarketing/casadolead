---
---
<section id="hero" class="hero-section">
  <!-- Decorative rotating blob -->
  <div class="hero-blob-rotate" id="hero-blob-rotate"></div>

  <div class="container hero-inner">
    <!-- Left column -->
    <div class="hero-content">
      <div class="hero-label anim-hidden anim-left">
        <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Especializados em Leads Qualificados
      </div>

      <h1 class="hero-title anim-hidden anim-left" style="--delay:100ms">
        Gere Leads Todos os Dias e Venda Mais...
      </h1>

      <p class="hero-subtitle anim-hidden anim-left" style="--delay:200ms">
        Atraia clientes qualificados através de Gestão de Tráfego de alta performance e otimização estratégica do seu perfil no Google.
      </p>

      <a href="https://wa.me/5511943722083?text=Olá%20Casa%20do%20Lead!%20Quero%20uma%20análise%20gratuita%20do%20meu%20negócio."
         class="btn hero-btn anim-hidden anim-left"
         target="_blank" rel="noopener"
         style="--delay:300ms">
        Quero uma Análise Gratuita do meu Negócio
      </a>
    </div>

    <!-- Right column: hero image + Lottie decorations -->
    <div class="hero-visual">
      <!-- Hero image -->
      <div class="hero-img-wrap anim-hidden" style="--delay:200ms">
        <img
          src="/images/hero.png"
          alt="Casa do Lead – Gestão de Tráfego"
          width="500"
          loading="eager"
        />
      </div>

      <!-- Play button Lottie (links to YouTube) -->
      <button class="hero-play anim-hidden anim-zoom" id="hero-play" aria-label="Assistir vídeo" style="--delay:200ms">
        <div id="lottie-play" class="lottie-play-inner"></div>
      </button>

      <!-- Decoration Lottie -->
      <div class="hero-deco anim-hidden" id="lottie-deco" style="--delay:700ms"></div>

      <!-- Particle Lottie (absolute) -->
      <div class="hero-particle anim-hidden anim-zoom" id="lottie-particle" style="--delay:1100ms"></div>
    </div>
  </div>

  <!-- YouTube lightbox -->
  <div class="lightbox-overlay" id="yt-lightbox" role="dialog" aria-modal="true" aria-label="Vídeo">
    <div class="lightbox-inner">
      <button class="lightbox-close" id="yt-close" aria-label="Fechar">✕</button>
      <iframe id="yt-iframe" src="" allow="autoplay; encrypted-media" allowfullscreen></iframe>
    </div>
  </div>
</section>

<style>
.hero-section {
  position: relative;
  background: var(--color-primary);
  padding: 120px 0 80px;
  overflow: hidden;
  min-height: 100vh;
  display: flex;
  align-items: center;
}
.hero-blob-rotate {
  position: absolute;
  width: 500px;
  height: 500px;
  background: radial-gradient(circle, rgba(245,144,13,0.12) 0%, transparent 70%);
  border-radius: 50%;
  right: -100px;
  top: 100px;
  pointer-events: none;
  will-change: transform;
}
.hero-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
}
.hero-label {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-label);
  font-size: 13px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 1.4px;
  color: var(--color-orange);
  margin-bottom: 20px;
}
.hero-title {
  font-family: var(--font-heading);
  font-size: clamp(36px, 5vw, 60px);
  font-weight: 700;
  color: var(--color-white);
  line-height: 1.15em;
  margin-bottom: 24px;
  transition-delay: var(--delay, 0ms);
}
.hero-subtitle {
  font-size: 16px;
  line-height: 1.8em;
  color: var(--color-text);
  max-width: 480px;
  margin-bottom: 36px;
  transition-delay: var(--delay, 0ms);
}
.hero-btn {
  font-size: 14px;
  padding: 16px 32px;
  transition-delay: var(--delay, 0ms);
}
/* Apply delay to animated items */
.anim-hidden { transition-delay: var(--delay, 0ms) !important; }

.hero-visual {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}
.hero-img-wrap {
  width: 100%;
  max-width: 500px;
  transition-delay: var(--delay, 0ms);
}
.hero-img-wrap img { width: 100%; border-radius: 16px; }

.hero-play {
  position: absolute;
  left: -22px;
  top: 50%;
  transform: translateY(calc(-50% + 10px));
  width: 80px;
  height: 80px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
  transition: transform 0.3s;
  transition-delay: var(--delay, 0ms);
}
.hero-play:hover { transform: translateY(calc(-50% + 10px)) scale(1.1); }
.lottie-play-inner { width: 80px; height: 80px; }

.hero-deco {
  position: absolute;
  right: -30px;
  bottom: -40px;
  width: 140px;
  height: 140px;
  pointer-events: none;
  transform: translate(30px, 120px);
  transition-delay: var(--delay, 0ms);
}
.hero-particle {
  position: absolute;
  top: 0;
  left: -30px;
  width: 120px;
  height: 120px;
  pointer-events: none;
  transform: translateX(-30px);
  transition-delay: var(--delay, 0ms);
}

@media (max-width: 1024px) {
  .hero-inner { grid-template-columns: 1fr; gap: 48px; }
  .hero-visual { max-width: 480px; margin: 0 auto; }
}
@media (max-width: 767px) {
  .hero-section { padding: 96px 0 60px; min-height: auto; }
  .hero-play { left: 0; }
}
</style>

<script>
  // Lottie animations
  if (typeof lottie !== 'undefined') {
    const playEl = document.getElementById('lottie-play');
    if (playEl) {
      lottie.loadAnimation({
        container: playEl,
        renderer: 'svg',
        loop: true,
        autoplay: true,
        path: 'https://lottie.host/8d397d9f-0953-4ccc-b29d-c5ad96337e74/6Hhj1LpNMo.json',
      });
    }
    const decoEl = document.getElementById('lottie-deco');
    if (decoEl) {
      lottie.loadAnimation({
        container: decoEl,
        renderer: 'svg',
        loop: true,
        autoplay: true,
        path: 'https://lottie.host/bc060a52-d9a1-4ced-b011-e026eb6169cc/9BvlclYIYv.json',
      });
    }
    const particleEl = document.getElementById('lottie-particle');
    if (particleEl) {
      lottie.loadAnimation({
        container: particleEl,
        renderer: 'svg',
        loop: true,
        autoplay: true,
        path: 'https://lottie.host/3f17be2b-8e00-4907-8974-0c84bba291d7/Vv1pHISM6f.json',
      });
    }
  }

  // Scroll rotation for blob
  const blob = document.getElementById('hero-blob-rotate');
  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(() => {
        if (blob) {
          blob.style.transform = `rotateZ(-${window.scrollY * 0.05}deg)`;
        }
        ticking = false;
      });
      ticking = true;
    }
  });

  // YouTube lightbox
  const playBtn = document.getElementById('hero-play');
  const lightbox = document.getElementById('yt-lightbox');
  const iframe = document.getElementById('yt-iframe') as HTMLIFrameElement;
  const closeBtn = document.getElementById('yt-close');
  const YT_URL = 'https://www.youtube.com/embed/XHOmBV4js_E?autoplay=1&feature=oembed';

  playBtn?.addEventListener('click', () => {
    if (iframe) iframe.src = YT_URL;
    lightbox?.classList.add('open');
    document.body.style.overflow = 'hidden';
  });
  const closeLightbox = () => {
    lightbox?.classList.remove('open');
    if (iframe) iframe.src = '';
    document.body.style.overflow = '';
  };
  closeBtn?.addEventListener('click', closeLightbox);
  lightbox?.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });
</script>
