---
const stats = [
  { value: 153, suffix: '',  label: 'Projetos Entregues',  icon: '/images/icon-9.png'  },
  { value: 80,  suffix: '+', label: 'Projetos Concluídos', icon: '/images/icon-10.png' },
  { value: 1047,suffix: 'K', label: 'Receita Gerada',      icon: '/images/icon-11.png' },
  { value: 39,  suffix: '+', label: 'Empresas Atendidas',  icon: '/images/icon-12.png' },
];
---
<section class="stats-section" aria-label="Números">
  <div class="container stats-inner">
    {stats.map((s) => (
      <div class="stat-item anim-hidden anim-zoom">
        <div class="stat-icon">
          <img src={s.icon} alt="" width="48" height="48" loading="lazy" />
        </div>
        <div class="stat-number">
          <span class="counter" data-to={s.value} data-suffix={s.suffix} data-duration="2000">0</span>{s.suffix}
        </div>
        <div class="stat-label">{s.label}</div>
      </div>
    ))}
  </div>
</section>

<style>
.stats-section {
  background: var(--color-dark);
  padding: 64px 0;
  border-top: 1px solid rgba(255,255,255,0.06);
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.stats-inner {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 32px;
  text-align: center;
}
.stat-item { padding: 16px; }
.stat-icon {
  width: 48px;
  height: 48px;
  margin: 0 auto 12px;
}
.stat-number {
  font-family: var(--font-heading);
  font-size: clamp(36px, 5vw, 54px);
  font-weight: 700;
  color: var(--color-orange);
  line-height: 1.1em;
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 2px;
}
.stat-label {
  font-family: var(--font-label);
  font-size: 13px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 1.4px;
  color: var(--color-text);
  margin-top: 8px;
}
@media (max-width: 767px) {
  .stats-inner { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 400px) {
  .stats-inner { grid-template-columns: 1fr 1fr; gap: 16px; }
}
</style>

<script>
  function animateCounters(entries: IntersectionObserverEntry[]) {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el = entry.target as HTMLElement;
      const to = parseInt(el.dataset.to || '0');
      const duration = parseInt(el.dataset.duration || '2000');
      const start = performance.now();
      const tick = (now: number) => {
        const elapsed = now - start;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = Math.floor(eased * to).toLocaleString('pt-BR');
        if (progress < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
      observer.unobserve(el);
    });
  }
  const observer = new IntersectionObserver(animateCounters, { threshold: 0.5 });
  document.querySelectorAll('.counter').forEach(el => observer.observe(el));
</script>
