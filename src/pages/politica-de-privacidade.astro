---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="Política de Privacidade – Casa do Lead">
  <Header />
  <main style="padding: 120px 0 80px; min-height: 80vh;">
    <div class="container" style="max-width: 760px;">
      <h1 style="font-family: var(--font-heading); color: var(--color-white); font-size: 40px; margin-bottom: 32px;">
        Política de Privacidade
      </h1>
      <div style="color: var(--color-text); line-height: 1.8em;">
        <p>Em breve. Entre em contato: <a href="mailto:contato@casadolead.com.br" style="color: var(--color-orange);">contato@casadolead.com.br</a></p>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
